{
  "$schema": "https://opencode.ai/config.json",
  "model": "llama.cpp/glm-4.7-flash",
  "small_model": "llama.cpp/gemma-4-12b",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Homelab (Llama.cpp)",
      "description": "Self-hosted RX 9070 llama-swap endpoint (Tailscale). Models hot-swap on demand.",
      "options": {
        "baseURL": "http://100.100.156.53:8080/v1"
      },
      "models": {
        "glm-4.7-flash": {
          "name": "GLM-4.7-Flash (coder)",
          "description": "30B-A3B agentic coder (~14 t/s). Default coding model.",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6-35B-A3B (daily)",
          "description": "35B-A3B MoE general/daily driver (~14 t/s).",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "gemma-4-12b": {
          "name": "Gemma-4-12B QAT (fast)",
          "description": "Fully-GPU 12B reasoning model (~57 t/s). Fast tasks / subagent.",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        },
        "shisa-12b-uncensored": {
          "name": "Shisa-Nemo-12B Abliterated (uncensored)",
          "description": "Fully-GPU 12B abliterated Mistral-Nemo. Uncensored chat/general.",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}
